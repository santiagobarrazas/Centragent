NODE_ENV=development

# Local durable stores
DATABASE_URL="postgresql://centragent:centragent@127.0.0.1:5432/centragent?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
QDRANT_URL="http://127.0.0.1:6333"
# The interactive launcher rewrites this to a provider/model/dimension-specific
# collection when embeddings are enabled to avoid Qdrant vector-size drift.
QDRANT_COLLECTION="centragent_memory"

# Local singleton MVP user. Keep stable so future auth can attach data.
MASTER_USER_ID="00000000-0000-4000-8000-000000000001"
MASTER_USER_NAME="Local Master"

# API / Web / MCP ports
API_HOST="127.0.0.1"
API_PORT="4000"
MCP_HOST="127.0.0.1"
MCP_PORT="3001"
CENTRAGENT_API_URL="http://127.0.0.1:4000"
NEXT_PUBLIC_API_URL="http://127.0.0.1:4000"
NEXT_PUBLIC_WS_URL="ws://127.0.0.1:4000/ws"

# Embeddings are optional in the MVP.
# Supported providers: disabled, ollama, openai, google.
EMBEDDING_PROVIDER="disabled"
# Usually set by pnpm start:local from the shared embedding model registry.
EMBEDDING_DIMENSIONS="768"

OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# OpenAI embeddings. text-embedding-3 models support dimensionality reduction.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
OPENAI_ORGANIZATION=""
OPENAI_PROJECT=""

# Google Gemini Developer API embeddings.
# Either GEMINI_API_KEY or GOOGLE_API_KEY may be used.
GEMINI_API_KEY=""
GOOGLE_API_KEY=""
GOOGLE_GENERATIVE_LANGUAGE_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
GOOGLE_EMBEDDING_MODEL="gemini-embedding-001"
